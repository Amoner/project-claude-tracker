#!/bin/sh
# Per-platform dispatcher. Plugin release CI fills in sibling
# tracker-cli-<target> binaries; this script picks the right one at runtime
# so the hooks.json command string is the same everywhere.

set -e
dir="$(cd "$(dirname "$0")" && pwd)"

case "$(uname -s)-$(uname -m)" in
  Darwin-arm64)   bin="$dir/tracker-cli-darwin-arm64" ;;
  Darwin-x86_64)  bin="$dir/tracker-cli-darwin-x64" ;;
  Linux-x86_64)   bin="$dir/tracker-cli-linux-x64" ;;
  Linux-aarch64)  bin="$dir/tracker-cli-linux-arm64" ;;
  *)
    echo "claude-tracker: unsupported platform $(uname -s)-$(uname -m)" >&2
    exit 1
    ;;
esac

if [ ! -x "$bin" ]; then
  echo "claude-tracker: missing binary $bin" >&2
  echo "claude-tracker: run \"/plugin update claude-tracker\" to reinstall" >&2
  exit 1
fi

exec "$bin" "$@"
